        "mixed_low_load",
        "mixed_medium_load",
        "mixed_overload"
      ],
      "metrics": [
        "arrival_rate",
        "throughput",
        "p99_ttft",
        "queue_delay",
        "goodput_ratio",
        "stalled_iterations"
      ]
